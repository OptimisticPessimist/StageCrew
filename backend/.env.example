# Database (Supabase pooled connection)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# Alembic マイグレーション用 (直接接続 port 5432)
MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Supabase Auth
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Frontend
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Debug
DEBUG=true
